rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allergy logs: user-owned documents (uid field must match auth)
    match /logs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Safe foods: same pattern
    match /safe_foods/{docId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // History cache (History.tsx saves under history/{userId})
    match /history/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profile docs (Profile, SignUp flows)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Dev-only connection test (LogReaction.tsx)
    match /test/{docId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /allergen_analysis/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /ai_analysis_results/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /risk_levels/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /overall_summary/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /test_kit_suggestions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
